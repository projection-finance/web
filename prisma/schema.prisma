datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// === Auth.js standard tables ===
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  projections   SavedProjection[]
  customTokens  CustomToken[]
  favoriteWallets FavoriteWallet[]
  recentWallets   RecentWallet[]
  cryptoPayments  CryptoPayment[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Stripe subscription
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   String    @default("free") // "free" | "pro"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// === Custom tokens (fictitious assets) ===
model CustomToken {
  id                          String   @id @default(cuid())
  userId                      String
  symbol                      String
  name                        String
  priceInUSD                  Float
  supplyAPY                   Float    @default(0)
  variableBorrowAPY           Float    @default(0)
  baseLTVasCollateral         Float    @default(0.75)
  reserveLiquidationThreshold Float    @default(0.8)
  reserveFactor               Float    @default(0.1)
  borrowingEnabled            Boolean  @default(true)
  usageAsCollateralEnabled    Boolean  @default(true)
  availableLiquidity          Float    @default(1000000)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, symbol])
}

// === Favorite wallets ===
model FavoriteWallet {
  id                 String    @id @default(cuid())
  userId             String
  address            String
  label              String
  lastHealthFactor   Float?
  lastHealthFactorAt DateTime?
  healthFactors      Json?     // Record<NetworkId, { hf: number | null, at: string }>
  monitoredNetworks  Json?     // NetworkId[] — explicit list; null = scan all (legacy)
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
}

// === Recent wallets ===
model RecentWallet {
  id        String   @id @default(cuid())
  userId    String
  address   String
  ensName   String?
  lastUsed  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address])
  @@index([userId, lastUsed(sort: Desc)])
}

// === Bug reports ===
model BugReport {
  id        String   @id @default(cuid())
  userId    String?
  email     String?
  message   String   @db.Text
  page      String?
  userAgent String?  @db.Text
  createdAt DateTime @default(now())
}

// === Crypto payments ===
model CryptoPayment {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  token     String             // "USDC" | "USDT"
  status    String   @default("pending") // "pending" | "confirmed" | "expired"
  txHash    String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// === Radar: whale positions at risk ===
model RadarPosition {
  id                    String   @id @default(cuid())
  walletAddress         String
  network               String   @default("ETHEREUM_V3")
  healthFactor          Float
  totalCollateralUSD    Float
  totalDebtUSD          Float
  mainCollateralSymbol  String
  mainCollateralAmount  Float    @default(0)
  mainCollateralPriceUSD Float
  liquidationPriceUSD   Float?
  liquidationThreshold  Float
  positionJson          Json?
  status                String   @default("active")
  firstSeenAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([walletAddress, network])
  @@index([network, status])
  @@index([totalDebtUSD(sort: Desc)])
  @@index([healthFactor])
}

// === Radar: recent liquidation events ===
model RadarLiquidation {
  id                    String   @id @default(cuid())
  txHash                String
  logIndex              Int
  walletAddress         String
  liquidatorAddress     String
  network               String   @default("ETHEREUM_V3")
  collateralAssetSymbol String
  collateralSeizedAmount Float
  collateralSeizedUSD   Float
  debtAssetSymbol       String
  debtRepaidAmount      Float
  debtRepaidUSD         Float
  timestamp             DateTime
  createdAt             DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([network, timestamp(sort: Desc)])
  @@index([collateralSeizedUSD(sort: Desc)])
}

// === Shared projections (public read-only links) ===
model SharedProjection {
  id        String   @id @default(cuid())
  slug      String   @unique
  type      String   @default("aave") // "aave" | "sandbox"
  userId    String?
  address   String
  network   String?  @default("ETHEREUM_V3")
  name      String
  details   String?  @db.Text
  config    Json
  aiSummary Json?    // AISummaryData — optional AI-generated summary
  createdAt DateTime @default(now())
}

// === Yield cache (shared across all users, refreshed every 30 min) ===
model YieldCache {
  id        String   @id @default("singleton")
  data      Json     // YieldsResponse
  updatedAt DateTime @updatedAt
}

// === CoinGecko contract address → coingeckoId mapping (persistent cache) ===
model CoingeckoMapping {
  id          String   @id // "platform:contractAddress" e.g. "ethereum:0xabc..."
  coingeckoId String
  updatedAt   DateTime @updatedAt
}

// === Yield snapshots (daily APY history for avg 7/30/90d) ===
model YieldSnapshot {
  id        String   @id @default(cuid())
  poolKey   String   // "aave:ethereum:USDC" or "morpho:base:STEAKUSDC"
  protocol  String   // "aave" | "morpho"
  symbol    String
  networkId String
  apy       Float
  date      DateTime @db.Date // one row per pool per day

  @@unique([poolKey, date])
  @@index([poolKey])
  @@index([date])
}

// === Custom: saved projections ===
model SavedProjection {
  id        String   @id @default(cuid())
  userId    String
  type      String   @default("aave")
  name      String
  address   String?
  network   String?  @default("ETHEREUM_V3")
  details   String?  @db.Text
  config    Json
  snapshots Json?
  aiSummary Json?    // AISummaryData — optional AI-generated summary
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
